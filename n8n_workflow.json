    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "=⚠️ Late Attendance Alert — {{ $json.date }}",
        "message": "=<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: auto; border: 1px solid #f0a500; border-radius: 8px; overflow: hidden;\">\n  <div style=\"background: #f0a500; padding: 20px;\">\n    <h2 style=\"color: white; margin: 0;\">⚠️ Late Attendance Notice</h2>\n  </div>\n  <div style=\"padding: 24px; background: #fff;\">\n    <p style=\"font-size: 16px;\">Dear <strong>{{ $json.name }}</strong>,</p>\n    <p style=\"font-size: 15px; color: #333;\">আমরা লক্ষ্য করেছি যে আপনি <strong>{{ $json.date }}</strong> তারিখে <span style=\"color: #f0a500; font-weight: bold;\">Late</span> হয়েছেন।</p>\n    <div style=\"background: #fff8e1; border-left: 4px solid #f0a500; padding: 12px 16px; margin: 16px 0; border-radius: 4px;\">\n      <p style=\"margin: 0; font-size: 14px;\"><strong>Employee ID:</strong> {{ $json.emp_id }}</p>\n      <p style=\"margin: 4px 0 0; font-size: 14px;\"><strong>Date:</strong> {{ $json.date }}</p>\n      <p style=\"margin: 4px 0 0; font-size: 14px;\"><strong>Status:</strong> Late</p>\n    </div>\n    <p style=\"font-size: 14px; color: #555;\">অনুগ্রহ করে সময়মতো অফিসে আসার চেষ্টা করুন। বারবার দেরি হলে এটি আপনার performance review-তে প্রভাব ফেলতে পারে।</p>\n    <p style=\"font-size: 14px; color: #555;\">যদি কোনো বিশেষ কারণ থাকে, অনুগ্রহ করে HR-এর সাথে যোগাযোগ করুন।</p>\n    <p style=\"margin-top: 24px; font-size: 14px;\">ধন্যবাদ,<br><strong>HR Department</strong></p>\n  </div>\n  <div style=\"background: #f9f9f9; padding: 12px 24px; text-align: center;\">\n    <p style=\"font-size: 12px; color: #999; margin: 0;\">This is an automated attendance notification. Please do not reply to this email.</p>\n  </div>\n</div>",
