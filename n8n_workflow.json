    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst result = [];\n\n// Today's date — MM/DD/YYYY format e banao\nconst now = new Date();\nconst mm = String(now.getMonth() + 1).padStart(2, '0');\nconst dd = String(now.getDate()).padStart(2, '0');\nconst yyyy = now.getFullYear();\nconst todayStr = `${mm}/${dd}/${yyyy}`; // e.g. \"03/16/2026\"\n\nfor (const item of items) {\n  const row = item.json;\n  const keys = Object.keys(row);\n\n  // Sob date column filter koro\n  const dateKeys = keys.filter(k => /\\d{1,2}\\/\\d{1,2}\\/\\d{4}/.test(k));\n  if (dateKeys.length === 0) continue;\n\n  // Exact today's column khojo\n  const todayKey = dateKeys.find(k => {\n    // Sheet e \"3/16/2026\" ba \"03/16/2026\" — dono handle korbe\n    const parts = k.split('/');\n    const kMM = parts[0].padStart(2, '0');\n    const kDD = parts[1].padStart(2, '0');\n    const kYYYY = parts[2];\n    return `${kMM}/${kDD}/${kYYYY}` === todayStr;\n  });\n\n  // Jodi aajker column sheet e na thake — skip\n  if (!todayKey) continue;\n\n  const rawStatus = (row[todayKey] || '').toString().trim();\n  const statusLower = rawStatus.toLowerCase();\n\n  let emailType = null;\n\n  if (statusLower.includes('absent') || rawStatus === '') {\n    emailType = 'absent';\n  } else if (statusLower.includes('late')) {\n    emailType = 'late';\n  } else if (statusLower.includes('leave')) {\n    emailType = 'leave';\n  }\n\n  if (!emailType) continue; // Present hole skip\n\n  result.push({\n    json: {\n      emp_id: row['EMP ID'] || '',\n      name: row['Name'] || '',\n      email: row['Email'] || '',\n      date: todayKey,\n      status: rawStatus || 'Absent',\n      emailType: emailType\n    }\n  });\n}\n\nreturn result;"
      },
